# ── Break the Loop — secrets template ─────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml for local development,
# OR paste these keys directly into the Streamlit Community Cloud
# dashboard under App Settings → Secrets.
#
# .streamlit/secrets.toml is gitignored — never commit your real keys.
# ──────────────────────────────────────────────────────────────────────────────

# Required: Anthropic Claude API key
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: Spotify integration (enables real library reading + save-to-library)
# Create an app at https://developer.spotify.com/dashboard
# Add your redirect URI under "Redirect URIs" in the app settings.
SPOTIFY_CLIENT_ID     = "your_spotify_client_id_here"
SPOTIFY_CLIENT_SECRET = "your_spotify_client_secret_here"

# For local dev: http://127.0.0.1:8501
# For Streamlit Cloud: https://spotify-breaktheloop.streamlit.app
SPOTIFY_REDIRECT_URI  = "http://127.0.0.1:8501"
